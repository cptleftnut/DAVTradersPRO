rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document (by mapping docId to uid)
    function isOwnerByDocId(docId) {
      return isAuthenticated() && docId.matches(request.auth.uid + '.*');
    }

    // Helper function to check if user owns the document (by field userId)
    function isOwnerByUserId() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function isRequestingAsSelf() {
       return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    match /userSettings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /tradingNotes/{noteId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || noteId.matches(request.auth.uid + '.*'));
      allow write: if isRequestingAsSelf() || noteId.matches(request.auth.uid + '.*');
    }

    match /tradeNotes/{noteId} {
      allow read, update, delete: if isOwnerByUserId();
      allow create: if isRequestingAsSelf();
    }

    match /journalEntries/{entryId} {
      allow read, update, delete: if isOwnerByUserId();
      allow create: if isRequestingAsSelf();
    }

    match /priceAlerts/{alertId} {
      allow read, update, delete: if isOwnerByUserId();
      allow create: if isRequestingAsSelf();
    }

    match /dailySummaries/{summaryId} {
      allow read, update, delete: if isOwnerByUserId();
      allow create: if isRequestingAsSelf();
    }

    match /tradingPresets/{presetId} {
      allow read, update, delete: if isOwnerByUserId();
      allow create: if isRequestingAsSelf();
    }

    match /orderHistory/{orderId} {
      allow read, update, delete: if isOwnerByUserId();
      allow create: if isRequestingAsSelf();
    }

    match /systemState/{docId} {
      allow read, write: if true;
    }

    match /wallet/{walletId} {
      allow read, write: if walletId == 'simulated' || isOwnerByDocId(walletId);
    }
    
    match /systemState/{stateId} {
      allow read, write: if stateId == 'botConfig' || isAuthenticated();
    }
  }
}
